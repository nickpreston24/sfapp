  <!--  embeds-->

  <PropertyGroup>
    <!-- This is the critical one -->
    <GenerateEmbeddedFilesManifest>true</GenerateEmbeddedFilesManifest>

    <!-- Optional but nice -->
    <EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems> <!-- if you want full control -->
  </PropertyGroup>

  <ItemGroup>

    <EmbeddedResource Include="**/*.template"/>
    <!--    <EmbeddedResource Include="templates/**"/>-->
    <!-- Add whatever folders you want -->
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CodeMechanic.Embeds.SourceGen\CodeMechanic.Embeds.SourceGen.csproj"

                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"
    />
    <ProjectReference Include="..\CodeMechanic.Embeds\CodeMechanic.Embeds.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="templates\foo\"/>

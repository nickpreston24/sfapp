<Project Sdk="Microsoft.NET.Sdk">

  <!-- REMOVE or comment these out; uncomment to DEBUG your SourceGenerators -->
  <!--
  <PropertyGroup>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>
  -->

  <PropertyGroup>
    <!-- Keep generated files out of your source tree and Rider noise -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>obj/Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <!-- Hide generated folder from Rider / solution explorer -->
    <Compile Remove="obj\Generated\**"/>
    <None Include="obj\Generated\**"/>
  </ItemGroup>


  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <ToolCommandName>sfapp</ToolCommandName>
    <PackageOutputPath>./nupkg</PackageOutputPath>
    <PackAsTool>True</PackAsTool>
    <IsPackable>True</IsPackable>
    <ToolName>sfapp</ToolName>
    <RootNamespace>sfapp</RootNamespace>

  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CodeMechanic.Async" Version="1.0.4"/>
    <PackageReference Include="CodeMechanic.Bash" Version="1.0.2"/>
    <PackageReference Include="CodeMechanic.Diagnostics" Version="1.0.4"/>

    <!--    <PackageReference Include="CodeMechanic.Embeds.SourceGen" Version="1.0.5" />-->
    <!--    <PackageReference Include="CodeMechanic.Embeds.SourceGen" Version="1.0.6"-->
    <!--                      PrivateAssets="all"-->
    <!--                      ExcludeAssets="runtime"/>-->

    <!--    <PackageReference Include="CodeMechanic.Embeds" Version="1.0.5"/>-->
    <PackageReference Include="CodeMechanic.FileSystem" Version="2.0.16"/>
    <PackageReference Include="CodeMechanic.RegularExpressions" Version="1.0.11"/>
    <PackageReference Include="CodeMechanic.Shargs" Version="1.0.5"/>
    <PackageReference Include="CodeMechanic.Types" Version="1.0.20"/>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.0.4"/>
    <PackageReference Include="Serilog" Version="4.2.0"/>
    <PackageReference Include="Serilog.Sinks.Console" Version="6.0.0"/>
    <PackageReference Include="Serilog.Sinks.File" Version="7.0.0"/>
    <PackageReference Include="Sharprompt" Version="3.0.0"/>
    <!--    <PackageReference Include="Microsoft.Extensions.FileProviders.Embedded" Version="9.0.0" />  &lt;!&ndash; or latest &ndash;&gt;-->
  </ItemGroup>


